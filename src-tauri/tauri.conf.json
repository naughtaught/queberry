{
    "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName": "fount",
    "version": "0.1.0",
    "identifier": "com.fount.app",
    "build": {
        "frontendDist": "../build",
        "devUrl": "http://localhost:5173",
        "beforeDevCommand": "bun run dev",
        "beforeBuildCommand": "bun run build"
    },
    "app": {
        "windows": [
            {
                "title": "fount",
                "width": 800,
                "height": 600,
                "resizable": true,
                "fullscreen": false,
                "transparent": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": ["icons/icon.ico"],
        "resources": ["lib/**/*"]
    }
}
