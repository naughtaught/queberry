		"@tailwindcss/vite": "^4.1.17",
		"@tauri-apps/cli": "^2.9.6",
		"@types/node": "^24",
		"@typescript-eslint/eslint-plugin": "^8.53.1",
		"@typescript-eslint/parser": "^8.53.1",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
